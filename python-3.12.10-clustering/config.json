{
  "packages": {
    "dependencies": [
      "pandas==2.2.3",
      "polars-lts-cpu==1.33.1",
      "polars-ds-lts-cpu==0.10.2",
      "kalign-python==3.6.0"
    ],
    "skip": {},
    "overrides": {},
    "platformSpecific": {},
    "buildWheel": {
      "kalign-python": {
        "linux-aarch64": {
          "reason": "No PyPI wheel for Linux ARM64; compile on the native runner"
        },
        "windows-x64": {
          "reason": "No PyPI wheel for Windows; threadpool uses pthread (absent on MSVC), build serial",
          "configSettings": [
            "cmake.define.USE_THREADPOOL=OFF",
            "cmake.define.USE_OPENMP=OFF"
          ]
        }
      }
    }
  }
}
